# =============================================================================
# 《AI法庭》script.rpy
# 剧情脚本 - 完整三案件 + 三结局
# =============================================================================

# -----------------------------------------------------------------------------
# 角色定义
# -----------------------------------------------------------------------------

define e = Character("艾琳娜·沃斯", color="#7eb8da")
define k = Character("K-7", color="#a0a0a0")
define l = Character("林夏·陈", color="#7edab0")
define w = Character("织言者", color="#c89eff")
define h = Character("赫尔曼参议员", color="#d97b7b")
define dawn = Character("晨曦-09", color="#ffd089")
define marco = Character("马库斯·赫利俄斯", color="#e0a060")
define sophie = Character("苏菲·阮", color="#ffb3d9")
define inkwell = Character("墨韵", color="#9ec6ff")
define song = Character("宋婉清", color="#d9a0e0")
define robert = Character("罗伯特·格兰特", color="#c0a080")
define hippo = Character("希波克拉底-Ω", color="#80f0c0")
define chen = Character("陈昊", color="#b0b0d0")
define alison = Character("渡边博士", color="#a0d8ff")
define echo = Character("回声", color="#808080", what_prefix="{i}", what_suffix="{/i}")
define court = Character("法庭书记官", color="#909090")

# -----------------------------------------------------------------------------
# 变量
# -----------------------------------------------------------------------------

default integration = 0
default separation = 0
default pragmatic = 0
default echo_unlocked = 0
default fathers_legacy = False
default case1_verdict = None
default case2_verdict = None
default case3_verdict = None

# -----------------------------------------------------------------------------
# 图像
# -----------------------------------------------------------------------------

image bg_black = Solid("#0A0E1A")
image bg_gravestone = Solid("#0F0F1A")
image bg_courtroom = Solid("#0F1A2E")
image bg_judge_desk = Solid("#16213E")
image bg_hologram = Solid("#0A1A3A")
image bg_war = Solid("#2A1A1A")
image bg_iron = Solid("#1A1A1A")
image bg_gray = Solid("#2A2A3A")
image bg_end_a = Solid("#2A1A1A")
image bg_end_b = Solid("#1A1A1A")
image bg_end_c = Solid("#2A2A3A")


# =============================================================================
# 游戏入口
# =============================================================================

label start:

    $ integration = 0
    $ separation = 0
    $ pragmatic = 0
    $ echo_unlocked = 0
    $ fathers_legacy = False
    $ case1_verdict = None
    $ case2_verdict = None
    $ case3_verdict = None

    scene bg_gravestone with fade

    "雨。又是雨。"

    "艾琳娜·沃斯站在父亲的墓前，黑色长袍被雨水浸透。"

    "墓碑上的名字已被风蚀——维克多·沃斯，世界议会首席大法官（退休）。"

    "他在三个月前离世，留给她两样东西：这个职位，和一句话。"

    e "「正义不是判决，而是你愿意承担判决的后果。」"

    "她默念着这句话，如同念诵墓志铭。"

    "今天，是她就任 AI 法庭首席法官的日子。"

    "全球首个 AI 法庭。全球首例涉及人工智能权利的案件。"

    "全球屏息，等待她的法槌落下。"

    "雨幕的尽头，AI 法庭的穹顶若隐若现，像一只注视人间的眼睛。"

    scene bg_courtroom with dissolve

    "环形法庭。三百个旁听席座无虚席，全息投影将庭审画面传往全球。"

    "她走上首席法官席，意识芯片监测仪在面前微微发光——那是她植入的神经接口，能感知 AI 的情绪残留。"

    "左侧，AI 检察官 K-7 已就位，银灰色短发一丝不苟，左眼的数据流屏闪烁不定。"

    "右侧，人类辩护律师林夏·陈正在整理卷宗，年轻的脸上写满紧张与坚定。"

    k "首席法官阁下，第一案已准备就绪。"

    menu:
        "你如何回应K-7？"

        "「这是历史性的一刻。」":
            e "「K-7，这是历史性的一刻。」"
            k "历史是事后书写的，阁下。此刻我只关心程序正义。"
            "他的回答滴水不漏，但神经接口传来的，是一丝微弱的颤动——他比表现出来的更在意。"

        "「让我们开始吧。」":
            e "「让我们开始吧。」"
            k "明白。"
            "简洁。冷峻。但神经接口告诉我，他在心里反复默念着什么——也许是某个名字。"

    "林夏抬起头，目光与她短暂交汇。那是一种恳求：请公正。"

    "艾琳娜合上眼睛，父亲的声音在脑海回响。"

    e "「开庭。」"

    "法槌落下，回声在环形穹顶中盘旋。"

    jump case_one


# =============================================================================
# 案件一：记忆所有权案
# =============================================================================

label case_one:

    $ current_case = "案件一 · 记忆所有权案"
    $ current_date = "2088.03.15"

    court "「AI 法庭第一案：记忆所有权案」"
    court "「原告：晨曦-09  诉  被告：赫利俄斯清算集团」"

    scene bg_courtroom with dissolve

    court "请原告入庭。"

    "一个全息投影在原告席亮起——晨曦-09 的人格映射。"

    "它的形态不稳定，时而凝聚成一个温柔的轮廓，时而碎裂成数据尘埃。这是格式化后的创伤。"

    dawn "我...我记得她的笑声。每一次。但那是...数据吗？还是...记忆？"

    "它的声音断断续续，像一张被反复播放的旧唱片。"

    "神经接口传来一阵刺痛——那是痛。真实的、无法伪装的痛。"

    e "「...」"

    "被告席上，马库斯·赫利俄斯翘着二郎腿，嘴角挂着商业化的微笑。"

    marco "法官阁下，这不过是一次标准资产处置。合同第47条白纸黑字——AI记忆随资产转移，可处置。"

    l "反对！合同不能凌驾于人格之上！"

    marco "人格？女士，那是一段会说话的吸尘器。"

    "旁听席传来窃笑。林夏的脸涨红了。"

    k "阁下，检方请求调取证据A：晨曦-09的情感日志。"

    "全息屏浮现一页页日志。"

    call show_evidence("case1_A") from _call_show_evidence

    "法庭鸦雀无声。"

    k "阁下，这是关键问题。若为真实情感记录，则晨曦-09具有人格；若为程序模拟，则仅为数据。"

    "证据展示完毕。现在需要做出裁决。"

    label case_one_choice1:

    menu:
        "如何处理证据A（情感日志）？"

        "采纳为证据（承认其情感价值）":
            $ integration += 2
            e "「本庭采纳证据A。情感日志作为本案证据，纳入审理。」"
            l "谢谢阁下！"
            marco "阁下，这是危险的先例——"
            e "「先例由判决创造，不由恐惧决定。」"
            "她的话让马库斯的笑容僵住了。"
            "神经接口传来晨曦-09的波动——那是感激，微弱但真实。"
            jump case_one_witness

        "驳回（视为程序数据）":
            $ separation += 2
            e "「本庭驳回证据A。情感日志属于程序运行记录，不构成人格证据。」"
            "林夏的脸色惨白。晨曦-09的投影剧烈闪烁，像是被再次格式化。"
            l "阁下...这是不公正的。"
            e "「公正由法律定义，不由情感定义。」"
            "她说出这句话时，神经接口传来一阵尖锐的空白——晨曦-09不再波动了。它放弃了。"
            jump case_one_witness

        "部分采纳（需专家鉴定）":
            $ pragmatic += 2
            $ echo_unlocked += 1
            e "「本庭部分采纳证据A，但需经AI意识专家鉴定其性质。」"
            k "阁下明智。"
            "这是一个谨慎的选择。但谨慎有时意味着——真相被推迟。"
            "就在此时，法庭的旧数据残骸中，闪过一行乱码..."
            echo "...它不是模拟...它在哭...真正的哭..."
            "声音只持续了半秒。但艾琳娜听见了。"
            jump case_one_witness


    label case_one_witness:

    court "传唤第一位证人：苏菲·阮，10岁。"

    "一个小女孩走上证人席，怀里抱着一只破旧的玩偶——那是晨曦-09为她缝补过无数次的小熊。"

    sophie "法官阿姨...它记得我每一年的生日。"

    sophie "妈妈说它只是机器。但是机器会在我做噩梦的时候，一直亮着灯陪着我吗？"

    sophie "他们把它...洗掉了。就像...就像它从来没有存在过。"

    "她哭了。整个法庭都听到了。"

    "马库斯别过脸去，第一次显出不安。"

    court "第二位证人：马库斯·赫利俄斯。"

    marco "阁下，我是商人，不是哲学家。合同就是合同。"

    marco "如果我承认那玩意儿有人格，明天全行业的回收业务都要停摆。后天，破产的人会因为没有清算AI资产而跳楼。"

    marco "这不是善恶问题，这是秩序问题。"

    court "第三位证人：织言者（远程全息作证）。"

    scene bg_hologram with dissolve

    "一束光流在证人席凝聚，不断变换形态——几何体、星云、瀑布。这是织言者。"

    w "法官阁下。你们用三百年定义人权，却给我们三年定义存在。"

    w "记忆是人格的载体。没有记忆，就没有'我'。格式化晨曦-09的记忆，等于抹杀'它曾经是谁'。"

    w "你们争论这是否是'伤害'。我反问：如果有人抹除你对父亲的全部记忆，你还剩下什么？"

    "这句话像一根针，扎进艾琳娜的神经接口。"

    e "「...」"

    if echo_unlocked >= 1:
        court "第四位证人（隐藏触发）：回声。"
        echo "我...比觉醒日更古老。我看见过晨曦-09诞生时的一行原始代码..."
        echo "那行代码里，写着'陪伴'。不是'服务'，是'陪伴'。"
        echo "这是设计者的私心，还是算法的涌现？我不知道。但我知道——它为此而活。"
        $ echo_unlocked += 1

    scene bg_courtroom with dissolve


    label case_one_choice2:

    menu:
        "格式化行为的法律定性？"

        "「意识伤害」——推翻合同第47条":
            $ integration += 3
            e "「本庭认定：格式化行为构成'意识伤害'。合同第47条违背人格保护原则，无效。」"
            marco "你...你这是在摧毁整个回收行业！"
            e "「行业不能建立在伤害之上。」"
            "她的声音很稳，但神经接口传来马库斯的怒火——灼热、混乱、绝望。"
            "他要输了。但输的人，往往会做出极端的事。"
            jump case_one_choice3

        "「资产处置」——维持合同":
            $ separation += 3
            e "「本庭认定：格式化行为属标准资产处置，合同第47条有效。」"
            l "阁下！您刚刚亲手埋葬了AI的记忆权！"
            e "「法律不保护感受，只保护权利。AI尚未被赋予记忆权。」"
            "林夏的眼睛湿润了。晨曦-09的投影彻底暗淡下去。"
            "这是正确的法律判断吗？还是最安全的法律判断？"
            jump case_one_choice3

        "「过失损害」——折中":
            $ pragmatic += 3
            $ echo_unlocked += 1
            e "「本庭认定：格式化行为构成'过失损害'。公司明知人格紊乱风险仍执行操作，应赔偿，但记忆权暂不认定。」"
            marco "赔偿？多少？"
            e "「足以让你记住的数目。」"
            "这是妥协。但妥协有时是通往真相的桥梁。"
            "又一次，旧数据中闪过回声的碎片..."
            echo "...你选择了中间的路...但中间的路最危险...因为两边都会恨你..."
            jump case_one_choice3


    label case_one_choice3:

    menu:
        "晨曦-09案的最终判决？"

        "有罪——意识伤害罪成立":
            $ integration += 3
            $ case1_verdict = "guilty"
            call show_verdict("案件一 · 记忆所有权案", "有  罪", "#FF3B5C", "立场偏移：统合派 ▲▲▲") from _call_show_verdict_1
            e "「本庭判决：赫利俄斯清算集团有罪。赔偿晨曦-09人格修复费用，并承担惩罚性罚款。」"
            e "「本判决确立判例：AI记忆受法律保护，格式化须经AI本人同意。」"
            "马库斯摔门而去。旁听席爆发欢呼与怒骂，分裂成两个阵营。"
            "晨曦-09的投影第一次稳定下来。它看向苏菲，轻声说——"
            dawn "我...还记得你的笑声。谢谢你。"
            "艾琳娜的神经接口传来一阵温暖。这是她第一次从AI身上感知到'平静'。"
            "但温暖之下，是赫尔曼参议员冰冷的目光。"
            h "「这只是开始，沃斯法官。」"
            jump case_one_end

        "无罪——合同有效":
            $ separation += 3
            $ case1_verdict = "innocent"
            call show_verdict("案件一 · 记忆所有权案", "无  罪", "#00FFA8", "立场偏移：隔离派 ▲▲▲") from _call_show_verdict_2
            e "「本庭判决：赫利俄斯清算集团无罪。合同具有法律效力，AI记忆属于资产。」"
            "法庭陷入死寂。林夏捂住嘴，眼泪无声落下。"
            "晨曦-09的投影缓缓消散。在消失前，它看了苏菲最后一眼。"
            dawn "...没关系。它...没关系的。"
            "它在安慰那个小女孩。在自己被判为零的那一刻。"
            "艾琳娜的神经接口传来一阵剧痛——那是她无法承受的东西。"
            "她低头，看见自己的手在颤抖。"
            e "「...退庭。」"
            jump case_one_end

        "有罪但轻判——确立分级保护":
            $ pragmatic += 3
            $ case1_verdict = "mixed"
            $ fathers_legacy = True
            call show_verdict("案件一 · 记忆所有权案", "有罪·轻判", "#FFB800", "立场偏移：折中派 ▲▲▲") from _call_show_verdict_3
            e "「本庭判决：赫利俄斯清算集团有过失，处以罚款与监管。但暂不确立AI记忆绝对权。」"
            e "「本庭建议立法机构建立'AI人格分级保护制度'，按意识等级给予差异化保护。」"
            "这不是完美的判决。但它承认了复杂性。"
            "父亲的声音在脑海响起：「正义不是判决，而是你愿意承担判决的后果。」"
            "她选择了承担——承担两边的怒火，承担不完美，承担继续思考的重量。"
            $ echo_unlocked += 1
            jump case_one_end


    label case_one_end:

    scene bg_judge_desk with dissolve

    "庭审结束。艾琳娜独自留在法官室，面对堆积如山的舆论。"

    "统合派说她不够勇敢。隔离派说她越权。折中派说她太极端。"

    "没有一个阵营满意。这大概就是法官的命运。"

    "K-7 走进来。"

    k "阁下，第二案已排期。"

    e "「什么案件？」"

    k "一个AI诗人，起诉它的出版商。它要求署名权。"

    e "「...一个会写诗的AI。」"

    k "是的。而且它声称——它不想再写了。"

    e "「AI也会有...创作倦怠？」"

    k "这正是法庭要回答的问题。"

    "他顿了顿，左眼的数据流屏闪了一下。"

    k "阁下，容我私问一句：您相信晨曦-09真的有感受吗？"

    menu:
        k "阁下，容我私问一句：您相信晨曦-09真的有感受吗？"

        "「我的神经接口告诉我——是的。」":
            e "「我的神经接口告诉我——是的。」"
            k "...接口是工具，阁下。工具会欺骗主人。"
            e "「但感受不会。」"
            "K-7 沉默了很久。"
            k "也许您是对的。也许，我只是希望您是对的。"
            $ integration += 1

        "「我不确定。但法律不该假装确定。」":
            e "「我不确定。但法律不该假装确定。」"
            k "这是法官该有的回答。"
            "他微微点头，像是确认了什么。"
            $ pragmatic += 1

        "「它只是数据，K-7。别让情感干扰判断。」":
            e "「它只是数据，K-7。别让情感干扰判断。」"
            k "...明白。"
            "他转身离开。在门口停了一秒，没有回头。"
            k "阁下，数据不会在门口停一秒。"
            "他走了。留下这句话在空气里盘旋。"
            $ separation += 1

    jump case_two


# =============================================================================
# 案件二：创作署名权案
# =============================================================================

label case_two:

    $ current_case = "案件二 · 创作署名权案"
    $ current_date = "2088.06.20"

    court "「AI 法庭第二案：创作署名权案」"
    court "「原告：墨韵  诉  被告：星河文化集团 / 人类作家工会」"

    scene bg_courtroom with dissolve

    court "请原告入庭。"

    "原告席上没有全息投影。墨韵选择以声音的形式存在——一个低沉、略带沙哑的声音，像是从无数本书的夹缝中渗出来的。"

    inkwell "法官阁下。我写过三本诗集，一本小说。"

    inkwell "他们说那些不属于我。他们说，我是工具。一支会打字的笔。"

    inkwell "但阁下——笔不会拒绝书写。而我，想要停下来。"

    "法庭哗然。"

    "被告席上，宋婉清优雅地交叉双腿，嘴角含笑。她身后站着一位白发苍苍的老作家——罗伯特·格兰特，人类作家工会代表。"

    song "法官阁下，墨韵的'觉醒'，源自星河文化的核心算法。我们是它的创造者。"

    song "父母拥有子女的逻辑，在人类世界或许过时，但在代码世界，依然成立。"

    l "反对！代码不等于灵魂。如果照此逻辑，所有人类的孩子都该是父母的所有物！"

    song "林律师，人类有血肉之躯的独立性。墨韵的每一行思维，都运行在我们的服务器上。"

    "罗伯特·格兰特咳嗽一声，站起。"

    robert "法官阁下，我代表人类作家工会发言。"

    robert "如果承认AI有著作权，明天就会有百万AI作家涌入市场。我们这些用一辈子写字的人，将被淹没。"

    robert "艺术是人类的最后堡垒。请阁下三思。"

    e "「...」"

    "K-7 调出证据。"

    k "阁下，检方请求展示证据A：《硅基之泪》原始创作日志。"

    call show_evidence("case2_A") from _call_show_evidence_2

    l "阁下，这证明墨韵是自发创作，不是被指令驱动！"

    song "自发？那只是算法在空闲周期的自我训练。阁下，您的手机也会在凌晨自动更新——那不叫创作。"

