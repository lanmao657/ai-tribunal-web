label show_evidence(evidence_id):
    $ renpy.show_screen("evidence_display", evidence_id=evidence_id)
    $ renpy.pause()
    $ renpy.hide_screen("evidence_display")
    return


label show_verdict(case_name, verdict_text, verdict_color, stance_text):
    $ renpy.show_screen("verdict_screen", case_name=case_name, verdict_text=verdict_text, verdict_color=verdict_color, stance_text=stance_text)
    $ renpy.pause()
    $ renpy.hide_screen("verdict_screen")
    return


